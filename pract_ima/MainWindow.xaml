<Window x:Class="pract_ima.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Умный дом" 
        Height="600" 
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Border Background="#2C3E50" Grid.Row="0">
            <TextBlock Text="🏠 Умный дом" FontSize="28" Foreground="White" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden" ContentRendered="MainFrame_ContentRendered"/>

        <Border Background="#34495E" Grid.Row="2">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="BtnBack" Content="◀ Назад" Width="100" Height="35" 
                        Background="#E74C3C" Foreground="White"
                        Click="BtnBack_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>