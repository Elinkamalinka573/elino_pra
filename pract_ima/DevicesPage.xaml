<Page x:Class="pract_ima.DevicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Устройства и датчики"
      Background="#F4F7F9">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📱 Устройства и датчики" 
                   FontSize="24" FontWeight="Bold"
                   Foreground="#1A5276"
                   HorizontalAlignment="Center"/>

        <!-- Фильтр -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <TextBlock Text="Фильтр по комнате:" VerticalAlignment="Center"/>
            <ComboBox x:Name="RoomFilter" Width="150" Margin="10,0" SelectionChanged="RoomFilter_SelectionChanged"/>
            <Button Content="🔄 Обновить" Width="80" Click="Refresh_Click"/>
        </StackPanel>

        <!-- Таблица устройств -->
        <ListView x:Name="DevicesListView" Grid.Row="2">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название" Width="150" DisplayMemberBinding="{Binding Название}"/>
                    <GridViewColumn Header="Тип" Width="120" DisplayMemberBinding="{Binding Тип}"/>
                    <GridViewColumn Header="Комната" Width="120" DisplayMemberBinding="{Binding Комнаты.Название}"/>
                    <GridViewColumn Header="Статус" Width="80" DisplayMemberBinding="{Binding Статус}"/>
                    <GridViewColumn Header="Текущее значение" Width="120" DisplayMemberBinding="{Binding Текущее_значение}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <TextBlock x:Name="StatusText" Grid.Row="3" Text="Готово" Margin="0,10,0,0" HorizontalAlignment="Center" Foreground="Gray"/>
    </Grid>
</Page>