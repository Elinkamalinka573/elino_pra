<Page x:Class="pract_ima.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная"
      Background="#F4F7F9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Кнопка "Устройства и датчики" -->
        <Button x:Name="BtnDevices" 
                Click="BtnDevices_Click"
                Grid.Row="1" Grid.Column="1"
                Width="300" Height="120"
                Margin="10"
                Background="#1A5276" 
                Foreground="White"
                FontSize="18"
                FontWeight="Bold">
            <StackPanel>
                <TextBlock Text="📱" FontSize="40" HorizontalAlignment="Center"/>
                <TextBlock Text="Устройства и датчики" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- Кнопка "Автоматизация" -->
        <Button x:Name="BtnAutomation" 
                Click="BtnAutomation_Click"
                Grid.Row="1" Grid.Column="2"
                Width="300" Height="120"
                Margin="10"
                Background="#1A5276" 
                Foreground="White"
                FontSize="18"
                FontWeight="Bold">
            <StackPanel>
                <TextBlock Text="⚙️" FontSize="40" HorizontalAlignment="Center"/>
                <TextBlock Text="Автоматизация" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</Page>